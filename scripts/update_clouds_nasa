#!/usr/bin/env python3
# NOTICE: This script is currently not used. Optional replacement for CreateCloudMap.

import argparse
import configparser
import os
import sys
import urllib.error
import urllib.request
from datetime import datetime, timedelta, timezone

# Define which section this specific script should look at
SCRIPT_SECTION = "clouds_nasa"


def download_clouds(**kwargs):
    base_url = kwargs.get("base_url")
    workdir = kwargs.get("workdir", "..")
    outfile = kwargs.get("outfile")
    width = int(kwargs.get("width", 2048))
    height = int(kwargs.get("height", 1024))

    # Construct the full output path
    os.makedirs(workdir, exist_ok=True)
    output_path = os.path.join(os.path.abspath(workdir), outfile)

    # Using the modern, timezone-aware UTC datetime
    # We still subtract 6 hours to ensure NASA's 'Best' layer has data processed
    try:
        now_utc = datetime.now(timezone.utc)
    except AttributeError:
        # Fallback for older Python 3 versions
        now_utc = datetime.now(timezone.utc)

    date_str = (now_utc - timedelta(hours=6)).strftime("%Y-%m-%d")

    params = {
        "SERVICE": "WMS",
        "VERSION": "1.1.1",
        "REQUEST": "GetMap",
        "LAYERS": "VIIRS_SNPP_CorrectedReflectance_TrueColor",
        "FORMAT": "image/jpeg",
        "TRANSPARENT": "FALSE",
        "STYLES": "",
        "SRS": "EPSG:4326",
        "BBOX": "-180,-90,180,90",
        "WIDTH": width,
        "HEIGHT": height,
        # Subtract 24 hours to ensure a complete world composite
        "TIME": (now_utc - timedelta(days=1)).strftime("%Y-%m-%d"),
    }

    query_string = "&".join([f"{k}={v}" for k, v in params.items()])
    full_url = f"{base_url}?{query_string}"

    try:
        os.makedirs(os.path.dirname(output_path), exist_ok=True)
        print(f"Fetching {width}x{height} clouds for {date_str} (UTC)")

        req = urllib.request.Request(
            full_url, headers={"User-Agent": "XPlanet-Cloud-Fetcher/1.0"}
        )
        with urllib.request.urlopen(req, timeout=60) as response:
            with open(output_path, "wb") as f:
                f.write(response.read())

        print(f"Cloud map successfully saved to: {output_path}")

    except urllib.error.HTTPError as e:
        print(f"NASA GIBS returned an error: {e.code} {e.reason}")
    except Exception as e:
        print(f"Failed to download clouds: {e}")


if __name__ == "__main__":
    parser = argparse.ArgumentParser(description="Update Clouds (NASA GIBS")
    parser.add_argument("--config", required=True, help="Path to main config")
    args = parser.parse_args()
    if not os.path.exists(args.config):
        raise FileNotFoundError(f"Config file not found at {args.config}")

    config = configparser.ConfigParser()
    config.read(args.config)
    s = SCRIPT_SECTION
    if not config.getboolean(s, "enabled", fallback=False):
        sys.exit(0)

    try:
        params = {
            "workdir": config.get("common", "workdir"),
            "base_url": config.get(s, "url"),
            "outfile": config.get(s, "outfile"),
            "width": config.getint(s, "width", fallback=2048),
            "height": config.getint(s, "height", fallback=1024),
        }
        download_clouds(**params)
    except Exception as e:
        print(f"Configuration error: {e}")
