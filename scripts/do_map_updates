#!/usr/bin/env python3

import argparse
import configparser
import logging
import os
import subprocess
import sys

# Setup logging
logging.basicConfig(
    level=logging.INFO,
    format="%(asctime)s [%(levelname)s] %(message)s",
    handlers=[logging.StreamHandler(sys.stdout)],
)
logger = logging.getLogger(__name__)


def run_task(script_name, config_path):
    """Executes a sub-script and returns True if successful."""
    # Assumes scripts are in the same directory as this orchestrator
    # or reachable via a 'scripts/' prefix.
    cmd = [sys.executable, script_name, f"--config={config_path}"]

    try:
        logger.info(f"Running: {script_name}")
        subprocess.run(cmd, check=True)
        return True
    except subprocess.CalledProcessError as e:
        logger.error(f"Task {script_name} failed with exit code {e.returncode}")
        return False
    except Exception as e:
        logger.error(f"Error executing {script_name}: {e}")
        return False


def main():
    parser = argparse.ArgumentParser(description="WRMS3 Map Update Orchestrator")
    parser.add_argument("--config", required=True, help="Path to worldmap.conf")
    args = parser.parse_args()

    if not os.path.exists(args.config):
        logger.error(f"Config file not found: {args.config}")
        sys.exit(1)

    config = configparser.ConfigParser()
    config.read(args.config)

    # Define the sequence of tasks and their associated scripts
    # This maintains the correct order for compositing and rendering
    tasks = [
        ("clouds", "scripts/update_clouds"),
        ("clouds_nasa", "scripts/update_clouds_nasa"),
        ("isobars", "scripts/update_isobars"),
        (
            "isobars",
            "scripts/update_composite_image",
        ),  # Composite depends on isobars/clouds
        ("storms", "scripts/update_storms"),
        ("quakes", "scripts/update_quakes"),
        ("shipping", "scripts/update_shipping"),
        ("volcanoes", "scripts/update_volcanoes"),
        ("xplanet", "scripts/run_xplanet"),
    ]

    logger.info("Starting WRMS3 Map Update Pipeline")

    for section, script in tasks:
        # Check if the section exists and if it is enabled
        if config.has_section(section):
            if config.getboolean(section, "enabled", fallback=False):
                success = run_task(script, args.config)
                if not success:
                    logger.warning(f"Pipeline continuing despite failure in {section}")
            else:
                logger.info(f"Section [{section}] is disabled. Skipping.")
        elif section == "isobars" and "update_composite_image" in script:
            # Handle the composite step which shares the isobars section logic
            success = run_task(script, args.config)
        else:
            logger.debug(f"No config section found for {section}, skipping {script}")

    logger.info("Map Update Pipeline Finished")


if __name__ == "__main__":
    main()
