# Make a copy of this file as 'worldmap.conf' in the same 'config'
# folder, and then customize the settings accordingly
[common]
workdir = .

[daemon]
# The World Map System Daemon is the controlling process for
# map updates and shipping data harvesting. Maps are updated
# morning to evening, and harvesting is done evening through
# to morning (if enabled below)
update_sleep = 120
harvest_sleep = 1200
morning = 06:00
evening = 21:00

[clouds]
# Clouds sourced via https://clouds.matteason.co.uk/
# Codebase here https://github.com/jmozmoz/cloudmap
# High quality images and kept reasonably up to date
enabled = True
outfile = data/cloud_map.jpg
width = 2048
height = 1024
force = False

[clouds_nasa]
# Optional source for clouds; use as backup for the above
enabled = False
url = https://gibs.earthdata.nasa.gov/wms/epsg4326/best/wms.cgi
outfile = data/cloud_map.jpg
width = 2048
height = 1024

[isobars]
enabled = True
url = https://nomads.ncep.noaa.gov/pub/data/nccf/com/gfs/prod
outfile = data/global_isobars.png
isobar_color = White
label_fontsize = 10
# Optional: isobar text labels outlined for better legibility
label_outline = True
# This is where we put the isobars image overlaid onto the clouds image
composite_outfile = data/cloud_map_with_isobars.jpg

[storms]
enabled = True
url = https://www.ncei.noaa.gov/data/international-best-track-archive-for-climate-stewardship-ibtracs/v04r01/access/csv/
outfile = data/storm_markers.txt
marker_color=yellow
marker_symbol = storm_symbol.png
regional_only=false
expiry_days=3

[quakes]
enabled = True
url = https://earthquake.usgs.gov/earthquakes/feed/v1.0/summary/all_day.csv
outfile = data/quake_markers.txt
marker_color = White
marker_symbol = earthquake_symbol.png
label_fontsize = 14
min_mag = 5.0

[volcanoes]
enabled = False
url = https://www.ngdc.noaa.gov/hazel/hazard-service/api/v1/volcanoes
outfile = data/volcano_markers.txt
marker_color = DeepPink
marker_symbol = volcano_symbol.png
# Show only volcanoes flagged as 'significant'
significant_only = True
# Volcanic Explosivity Index (VEI):
# 0	non-explosive
# 1 Small
# 2	Moderate
# 3	Moderate-Large
# 4	Large
# 5	Very Large
# 6	Paroxysmal
# 7	Colossal
# 8	Super colossal
# Show only volcanoes with vei equal or greater than:
vei_min = 5
# Volcano eruption date codes:
# D1 - 1964 or later
# D2 - 1900 to 1963
# D3 - 1800 to 1899
# D4 - 1700 to 1799
# D5 - 1500 to 1699
# D6 - A.D.1 to 1499
# D7 - B.C. (Holocene)
# U  - Undated, prob. Holocene
# Q  - Quaternary (very fucking old!)
# ?  - Uncertain Holocene
# Show only volcanoes with on of this list of date codes
erupt_date_codes = ["D1"]

[shipping]
enabled = False
# Needs an API Key in your .env file; see https://aisstream.io/documentation
url = wss://stream.aisstream.io/v0/stream
outfile = data/ship_markers.txt
# Time to listen for positional data broadcasts
listen_for_positional_data = 240
# Order is important! [Lat South, Lon West, Lat North, Lon East]
# Example Bounding Box List:
# 1. NZ/Australia (Tasman Sea focused)
# 2. Strait of Hormuz (Entrance to Persian Gulf)
# 3. Suez Canal (North & South entrances)
# 4. Strait of Gibraltar (Entrance to Mediterranean)
# 5. English Channel (Dover Strait focused)
bbox = [[[-48.0, 140.0], [-10.0, 180.0]], [[22.0, 52.0], [28.0, 62.0]], [[27.0, 30.0], [33.0, 35.0]],[[34.0, -9.0], [37.0, -4.0]], [[48.0, -6.0], [52.0, 3.0]]]
harvest_bbox = [[[-48.0, 140.0], [-10.0, 180.0]], [[22.0, 52.0], [28.0, 62.0]], [[27.0, 30.0], [33.0, 35.0]],[[34.0, -9.0], [37.0, -4.0]], [[48.0, -6.0], [52.0, 3.0]]]
marker_color = orange
label_fontsize = 12
# Show only these classes of vessel. Possible values: ["Passenger Ship", Tanker", "Cargo"]
# Leave as an empty list [] to show all vessels
filter_show_ship_classes = ["Tanker"]
# Show names for specific classes of ship (same options as for filter_show_ship_classes)
# Leave as an empty list to suppress all names
filter_show_names_for_classes = ["Tanker"]
# Filter out ships with speeds < 1 knots or flagged as moored/anchored
filter_only_active_ships = False
# Show ships with lengths >= this (metres 0=>no filtering)
# Use this to filter out the small-fry
filter_ships_minimum_length = 150

[shipping_harvester]
enabled = False
# Needs an API Key in your .env file; see https://aisstream.io/documentation
url = wss://stream.aisstream.io/v0/stream
# Ships will be added/updated every time the harvester is run
static_database = data/ship_cache.json
# Time to listen for static data broadcasts
listen_for_static_data = 1200
# Where in the World we look for harvesting ship data
bbox = [[[-90.0, -180.0], [90.0, 180.0]]]
# Split harvest into this many chunks by longitude; this will
# decrease load on the streaming service and avoid possible
# throttling and/or blocking by the service
harvest_chunks = 8

[xplanet]
enabled = True
projection = rectangular
# Set to the geometry of your desktop
geometry = 1920x1200
# Set to centre over your location
longitude = 175
# This is the final map image we generate
base_filename = worldmap.jpg
# This file holds standard XPlanet configration settings
# See https://xplanet.sourceforge.net/README.config
xplanet_conf = config/xplanet.conf
