#!/usr/bin/env python3
import argparse
import configparser
import logging
import os
import subprocess
import sys

# Setup logging to match the rest of the system
logging.basicConfig(
    level=logging.INFO,
    format="%(asctime)s [%(levelname)s] %(message)s",
    handlers=[logging.StreamHandler(sys.stdout)],
)
logger = logging.getLogger(__name__)

SCRIPT_SECTION = "shipping_harvester"


def main():
    parser = argparse.ArgumentParser(description="Ship Data Harvest")
    parser.add_argument("--config", required=True, help="Path to main config")
    args = parser.parse_args()

    if not os.path.exists(args.config):
        logger.error(f"Config file not found: {args.config}")
        sys.exit(1)

    config = configparser.ConfigParser()
    config.read(args.config)

    # The script which harvests the data
    harvester_script = "scripts/harvest_ship_data"

    if config.has_section(SCRIPT_SECTION):
        enabled = config.getboolean(SCRIPT_SECTION, "enabled", fallback=False)
        if enabled:
            logger.info("Beginning ship data harvest")
            try:
                # Execute the actual harvester
                subprocess.run(
                    [sys.executable, harvester_script, f"--config={args.config}"],
                    check=True,
                )
                logger.info("Ship data harvest finished successfully.")
            except subprocess.CalledProcessError as e:
                logger.error(f"Harvester failed with exit code {e.returncode}")
                sys.exit(1)
            except Exception as e:
                logger.error(f"Unexpected error during harvest: {e}")
                sys.exit(1)
        else:
            logger.info(
                f"Section [{SCRIPT_SECTION}] is disabled in config. Skipping harvest."
            )
    else:
        logger.warning(
            f"No [{SCRIPT_SECTION}] section found in {args.config}. Nothing to do."
        )


if __name__ == "__main__":
    main()
